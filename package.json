{
  "name": "convex-solidjs",
  "version": "0.0.2",
  "description": "Convex SolidJS Client",
  "license": "MIT",
  "author": "jiangda2@illinois.edu",
  "contributors": [],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/frank-iii/convex-solidjs.git"
  },
  "bugs": {
    "url": "https://github.com/frank-iii/convex-solidjs/issues"
  },
  "files": [
    "dist"
  ],
  "private": false,
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "typesVersions": {},
  "scripts": {
    "dev": "vp dev dev",
    "build": "vp pack",
    "test": "vp run test:all",
    "test:client": "vp test",
    "test:ssr": "vp test --mode ssr",
    "prepublishOnly": "pnpm build",
    "format": "vp fmt src dev --write --ignore-path .gitignore",
    "lint": "vp run lint:all",
    "lint:code": "vp lint src --quiet --ignore-path .gitignore",
    "lint:types": "tsc --noEmit",
    "update-deps": "pnpm up -Li"
  },
  "peerDependencies": {
    "solid-js": "^2.0.0-beta.2"
  },
  "devDependencies": {
    "@solidjs/web": "2.0.0-beta.2",
    "@types/node": "^24.12.0",
    "esbuild": "^0.27.4",
    "jsdom": "^26.1.0",
    "solid-js": "2.0.0-beta.2",
    "typescript": "^5.9.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.11",
    "vite-plugin-solid": "3.0.0-next.2",
    "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.11",
    "vite-plus": "0.1.11"
  },
  "keywords": [
    "solid"
  ],
  "engines": {
    "node": ">=24",
    "pnpm": ">=10.0.0"
  },
  "dependencies": {
    "convex": "^1.32.0"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@0.1.11",
      "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.11"
    }
  }
}
