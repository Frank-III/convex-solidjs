{
  "name": "convex-solidjs",
  "version": "0.0.2",
  "description": "Convex SolidJS Client",
  "license": "MIT",
  "author": "jiangda2@illinois.edu",
  "contributors": [],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/frank-iii/convex-solidjs.git"
  },
  "bugs": {
    "url": "https://github.com/frank-iii/convex-solidjs/issues"
  },
  "files": [
    "dist"
  ],
  "private": false,
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "typesVersions": {},
  "scripts": {
    "dev": "vite serve dev",
    "build": "tsdown",
    "test": "concurrently pnpm:test:*",
    "test:client": "vitest",
    "test:ssr": "pnpm run test:client --mode ssr",
    "prepublishOnly": "pnpm build",
    "format": "prettier --ignore-path .gitignore -w \"src/**/*.{js,ts,json,css,tsx,jsx}\" \"dev/**/*.{js,ts,json,css,tsx,jsx}\"",
    "lint": "concurrently pnpm:lint:*",
    "lint:code": "eslint --max-warnings 0 --ext .ts,.tsx src",
    "lint:types": "tsc --noEmit",
    "update-deps": "pnpm up -Li"
  },
  "peerDependencies": {
    "solid-js": "^2.0.0-beta.1"
  },
  "devDependencies": {
    "@solidjs/web": "2.0.0-beta.1",
    "@types/node": "^24.12.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "concurrently": "^9.2.1",
    "esbuild": "^0.25.12",
    "jsdom": "^26.1.0",
    "prettier": "3.8.1",
    "solid-js": "2.0.0-beta.1",
    "tsdown": "^0.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-solid": "3.0.0-next.2",
    "vitest": "^3.2.4"
  },
  "keywords": [
    "solid"
  ],
  "engines": {
    "node": ">=24",
    "pnpm": ">=10.0.0"
  },
  "dependencies": {
    "convex": "^1.32.0",
    "oxfmt": "^0.36.0"
  }
}
